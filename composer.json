{
    "name": "mylaraveltools/minimalist",
    "description": "Minimalist — declarative monochrome admin panel for Laravel with Livewire and Tailwind",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "admin",
        "panel",
        "livewire",
        "tailwind",
        "mylaraveltools",
        "minimalist",
        "monochrome"
    ],
    "authors": [
        {
            "name": "Alberto Gallardo Morales",
            "email": "gallardev.98@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/gallardev98-blip/minimalist-panel/issues",
        "source": "https://github.com/gallardev98-blip/minimalist-panel"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "dompdf/dompdf": "^3.0",
        "livewire/livewire": "^3.5",
        "phpoffice/phpspreadsheet": "^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "mylaraveltools/alertas": "Toasts y modales en auth y acciones del panel (integración opcional vía panel.integrations.alertas)"
    },
    "autoload": {
        "psr-4": {
            "MyLaravelTools\\Panel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MyLaravelTools\\Panel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MyLaravelTools\\Panel\\PanelServiceProvider"
            ],
            "aliases": {
                "Panel": "MyLaravelTools\\Panel\\Facades\\Panel"
            }
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "prefer-stable": true
}
